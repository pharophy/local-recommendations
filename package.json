{
  "name": "local-recommendations",
  "version": "0.1.0",
  "private": true,
  "description": "Daily SoCal experience discovery agent with Airtable persistence and email summaries.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "bin": {
    "socal-discovery-agent": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\"",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run build && node --import ./test/vitest.bootstrap.mjs ./node_modules/vitest/vitest.mjs run --config ./vitest.config.mjs --configLoader runner --pool threads --poolOptions.threads.singleThread",
    "daily": "tsx src/cli/index.ts daily-run",
    "daily:dry": "tsx src/cli/index.ts daily-run --dry-run",
    "check:airtable": "tsx src/cli/index.ts check-airtable",
    "seed:metadata": "tsx src/cli/index.ts seed-search-metadata",
    "clear:experiences": "tsx src/cli/index.ts clear-experience-tables",
    "docs:schema": "tsx src/cli/index.ts docs-airtable-schema"
  },
  "keywords": [
    "airtable",
    "typescript",
    "node",
    "discovery-agent",
    "socal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.1.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "nodemailer": "^7.0.3",
    "p-limit": "^7.2.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  }
}
